# Flask 后端生产环境示例
# 将 yourdomain.com 替换成你的真实域名
FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret
CORS_ORIGINS=https://app.yourdomain.com,https://your-pages-project.pages.dev
DATABASE_URL=sqlite:///ai_efficiency.db
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 如果不用用户个人 API Key，可以设置全局 DeepSeek Key
# DEEPSEEK_API_KEY=sk-xxxxxxxx
